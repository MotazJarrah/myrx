# ──────────────────────────────────────────────────────────────────────
# MyRX root .env template
# Copy this to .env.local (gitignored) and fill in the actual values.
# Per-app .env files (web/, mobile/, workers/) can override these.
# ──────────────────────────────────────────────────────────────────────

# ── Stripe (Coach Platform v1 — Phase 2) ─────────────────────────────
# Test mode keys (safe to share between team in private channels)
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...
STRIPE_SECRET_KEY_TEST=sk_test_...

# Live mode keys (NEVER share — pull from dashboard at deploy time)
# Get from: https://dashboard.stripe.com/apikeys
# STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...
# STRIPE_SECRET_KEY_LIVE=sk_live_...

# Mode toggle (test or live)
STRIPE_MODE=test

# Webhook signing secret (set after creating a webhook endpoint in Stripe)
# Get from: https://dashboard.stripe.com/test/webhooks/<endpoint-id>/signing_secret
STRIPE_WEBHOOK_SECRET_TEST=whsec_...
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_...

# ── Stripe Product + Price IDs ───────────────────────────────────────
# Created via the Stripe API on May 24 2026 during Phase 2 setup.
# Coach subscription tiers (recurring monthly/yearly).
# Annual prices = 10 months at monthly rate (2 months free).
STRIPE_PRODUCT_COACH_STARTER_TEST=prod_...
STRIPE_PRICE_COACH_STARTER_MONTHLY_TEST=price_...   # $19/mo
STRIPE_PRICE_COACH_STARTER_YEARLY_TEST=price_...    # $190/yr

STRIPE_PRODUCT_COACH_PRO_TEST=prod_...
STRIPE_PRICE_COACH_PRO_MONTHLY_TEST=price_...       # $39/mo
STRIPE_PRICE_COACH_PRO_YEARLY_TEST=price_...        # $390/yr

STRIPE_PRODUCT_COACH_UNLIMITED_TEST=prod_...
STRIPE_PRICE_COACH_UNLIMITED_MONTHLY_TEST=price_... # $99/mo
STRIPE_PRICE_COACH_UNLIMITED_YEARLY_TEST=price_...  # $990/yr

# B2C one-time tiers (non-recurring, lifetime unlock).
STRIPE_PRODUCT_SEMIRX_TEST=prod_...
STRIPE_PRICE_SEMIRX_ONETIME_TEST=price_...          # $39 one-time

STRIPE_PRODUCT_FULLRX_TEST=prod_...
STRIPE_PRICE_FULLRX_ONETIME_TEST=price_...          # $59 one-time
