# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment files — NEVER commit. All secrets live in GHA / shell env / wrangler / Supabase.
# `*.local` above already catches `.env.local`, but be explicit for the rest.
.env
.env.*
!.env.example

# Wrangler local secrets (used for dev + as the source from which we `wrangler secret put`)
.dev.vars
**/.dev.vars

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude worktrees (local dev only)
.claude/worktrees/

# OpenNutrition seed dataset — multi-hundred-MB TSV used once for D1 import.
# Keep on disk for re-import but never commit it (kills git push over flaky links).
opennutrition/

# Bulk-import source data — USDA + OpenNutrition archives, multi-GB.
# Downloaded fresh each rebuild, then deleted. Never goes in git.
scripts/bulk_import/data/

# Belt-and-suspenders: any USDA / ON archive anywhere in the tree.
FoodData_Central_csv_*.zip
FoodData_Central_csv_*/
opennutrition-dataset-*.zip
opennutrition_foods.tsv

# Claude session state — local only
.claude/scheduled_tasks.lock

# Cloudflare wrangler local cache (account info, build state)
.wrangler/

# Bulk-import intermediate artifacts
scripts/bulk_import/myrx_backup.json
scripts/bulk_import/data/

# Body composition silhouette source (Adobe Stock — licensed asset,
# do NOT commit). Extraction tooling lives at branding/extract_bodycomp.py
# and outputs to mobile/assets/bodycomp/. The Adobe Stock source PNG +
# debug preview composites should never enter the repo.
branding/bfp.jpg
branding/bodycomp_preview.png

# Versioned copy of the wizard-strings XLSX written when Excel has the
# canonical file open. Canonical docs/plan_wizard_strings.xlsx is the
# tracked truth; timestamped variants are throwaway.
docs/plan_wizard_strings_*.xlsx
