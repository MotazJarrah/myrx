# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment files — NEVER commit. All secrets live in GHA / shell env / wrangler / Supabase.
# `*.local` above already catches `.env.local`, but be explicit for the rest.
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude worktrees (local dev only)
.claude/worktrees/

# OpenNutrition seed dataset — multi-hundred-MB TSV used once for D1 import.
# Keep on disk for re-import but never commit it (kills git push over flaky links).
opennutrition/

# Cloudflare wrangler local cache (account info, build state)
.wrangler/
